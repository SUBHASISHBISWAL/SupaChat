# ==============================================================================
# SupaChat Environment Configuration Template
# Do NOT commit the actual `.env` file containing real secrets to version control.
# ==============================================================================

# -- Supabase Database --
# Retrieve these from Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
# CRITICAL: Use the service_role key to allow the backend to bypass RLS for analytical queries safely
SUPABASE_SERVICE_KEY=eyJhbGci...

# -- Hugging Face Inference --
# Retrieve from Hugging Face -> Settings -> Access Tokens (Read access is fine)
HF_TOKEN=hf_...
# Change only if you want to test smaller models
HF_MODEL_ID=Qwen/Qwen2.5-72B-Instruct

# -- FastAPI Configuration --
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=4000
